# Copy this file to .env and fill in your values

# The email address where form submissions will be sent
CONTACT_EMAIL=Bobby@BLstrength.com

# SMTP settings (Gmail example below)
# For Gmail: enable 2FA, then create an App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
